    "url": "https://github.com/florida117/Homebridge-Hive-Thermostat/issues"
  },
  "homepage": "https://github.com/florida117/Homebridge-Hive-Thermostat#readme",
  "main": "dist/index.js",
  "engines": {
    "homebridge": ">=1.6.0 || ^2.0.0-beta.0",
