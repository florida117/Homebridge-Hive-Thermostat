{
  "displayName": "Homebridge Hive Thermostat",
  "name": "homebridge-hive-thermostat",
  "version": "1.0.0",
  "description": "Homebridge plugin exposing Hive heating zones and hot water to HomeKit via the Hive cloud API (Cognito SRP auth with SMS 2FA).",
  "license": "MIT",
  "author": "Kurtis Bell",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/florida117/Homebridge-Hive-Thermostat.git"
  },
  "bugs": {
    "url": "https://github.com/florida117/Homebridge-Hive-Thermostat/issues"
  },
  "homepage": "https://github.com/florida117/Homebridge-Hive-Thermostat#readme",
  "main": "dist/index.js",
  "files": [
    "dist",
    "config.schema.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "homebridge": ">=2.0.0",
    "node": "^22 || ^24"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "watch": "npm run build && nodemon",
    "lint": "eslint src/**.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "hive",
    "thermostat",
    "heating",
    "hot-water",
    "homekit"
  ],
  "dependencies": {
    "amazon-cognito-identity-js": "^6.3.12",
    "node-fetch": "^2.7.0"
  },
  "overrides": {
    "js-cookie": "3.0.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-fetch": "^2.6.11",
    "homebridge": "^2.1.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  }
}
